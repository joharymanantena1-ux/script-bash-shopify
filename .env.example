# ============================================================
# Base de données MariaDB (Wee)
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nom_de_la_base
DB_USER=utilisateur
DB_PASSWORD=mot_de_passe

# ============================================================
# Shopify Admin API
# ============================================================
SHOPIFY_STORE=votre-boutique.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01

# ============================================================
# Paramètres d'export
# ============================================================
OUTPUT_DIR=output
DESIGNER_TYPE_ID=139
DEFAULT_TRANS_ID=1

# ============================================================
# Paramètres de test (produit unique)
# Renseignez au moins l'un des trois champs
# ============================================================
TEST_PRODUCT_ID=12345
TEST_PRODUCT_SKU=MON-SKU-001
TEST_PRODUCT_HANDLE=mon-produit-handle

# ============================================================
# Contrôle de sécurité
# DRY_RUN=true  => aucune écriture Shopify (mode simulation)
# DRY_RUN=false => écriture réelle (à activer volontairement)
# ============================================================
DRY_RUN=true

# ============================================================
# Google Drive (images designers)
# ============================================================
GOOGLE_CREDENTIALS_PATH=credential-regardbeauty.json
GOOGLE_TOKEN_PATH=token.json
GOOGLE_DRIVE_FOLDER_NAME=master

# ============================================================
# Source images designers (optionnel)
# Si votre CDN ou serveur est publiquement accessible, renseignez
# l'URL de base. L'image sera téléchargée par Shopify directement.
# Exemple : IMAGE_BASE_URL=https://cdn.monsite.com/images/designers
# L'URL finale = IMAGE_BASE_URL/{image_file}
# ============================================================
IMAGE_BASE_URL=
